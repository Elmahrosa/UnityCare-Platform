# ============================================================
# UnityCare Platform — Consolidated Environment Variables
# Merge of: Unity-Care-Hospital-Sovereign, UCH-Backend,
#           U_C_H2 (blockchain/Pi), UCH-Buyer-Kit, salma
# ============================================================

# ── Server ────────────────────────────────────────────────
PORT=5000
NODE_ENV=development
CORS_ORIGIN=http://localhost:3000

# ── Database (MongoDB / PostgreSQL) ───────────────────────
# MongoDB (primary)
MONGO_URI=mongodb://uch_admin:change_me_now@mongo:27017/unity_care_hospital?authSource=admin
MONGO_USER=uch_admin
MONGO_PASS=change_me_now

# PostgreSQL (alternative / secondary)
DATABASE_URL=postgresql://user:password@localhost:5432/unitycare?schema=public

# ── Auth (JWT) ────────────────────────────────────────────
JWT_ACCESS_SECRET=replace_with_secure_random_string_min_48_chars
JWT_REFRESH_SECRET=replace_with_different_secure_random_string_min_48_chars
JWT_EXPIRES_IN=1h
JWT_REFRESH_EXPIRES_IN=7d
JWT_TTL_SECONDS=3600

# ── AI / ML ──────────────────────────────────────────────
# ML_API_URL=https://your-ml-api.example.com
# OPENAI_API_KEY=
# ANTHROPIC_API_KEY=

# ── Emergency Dispatch (Twilio) ───────────────────────────
# TWILIO_ACCOUNT_SID=
# TWILIO_AUTH_TOKEN=
# TWILIO_FROM_NUMBER=

# ── Pi Network (from U_C_H2) ──────────────────────────────
# PI_API_KEY=
# PI_WALLET_ADDRESS=

# ── Blockchain (from U_C_H2 / salma) ──────────────────────
# BLOCKCHAIN_PROVIDER_URL=
# SMART_CONTRACT_ADDRESS=

# ── Telehealth / Video ───────────────────────────────────
# VIDEO_SDK_KEY=
# VIDEO_SDK_SECRET=

# ── Monitoring (Prometheus) ──────────────────────────────
# PROMETHEUS_PUSH_GATEWAY=

# ── Deployment ───────────────────────────────────────────
# VERCEL_TOKEN=
# VERCEL_ORG_ID=
# VERCEL_PROJECT_ID=
# DOCKER_REGISTRY=
